# Example environment configuration for API server
# Copy this to .env and fill in your actual values

# Test/Client Configuration
SERVER_URL = "http://100.x.y.z:8080"
AUTH_KEY = "your-auth-key-here"

# Server Configuration (for app.py)
# If running locally with Docker containers:
OLLAMA_URL = "http://localhost:11434"
CHROMADB_URL = "http://localhost:8000"

# If running on server with different network setup:
# OLLAMA_URL = "http://localhost:11434"  (Ollama runs on host, not in container)
# CHROMADB_URL = "http://chromadb:8000"  (ChromaDB in Docker container)
